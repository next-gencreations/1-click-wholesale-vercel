{
  "expo": {
    "name": "1-Click Profit Finder",
    "slug": "one-click-profit-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon-512.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF4F2"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nextgencreations.profitfinder"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./icon-512.png",
        "backgroundColor": "#EEF4F2"
      },
      "package": "com.nextgencreations.profitfinder",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./icon-192.png"
    }
  }
}
